# Recursive forecast so lag_1 and lag_12 are available at each step
def recursive_forecast_with_exog(
    result_obj,
    history_y: pd.Series,
    future_index,
    acc_future: pd.Series,
) -> pd.Series:
    preds = []
    state = result_obj
    hist = history_y.copy().astype(float)

    for dt in future_index:
        lag_1 = float(hist.iloc[-1])
        lag_12 = float(hist.iloc[-12])
        month_num = int(pd.to_datetime(dt).month)
        active_accounts = float(acc_future.loc[dt])

        x_next = pd.DataFrame(
            {
                'active_accounts': [active_accounts],
                'month_num': [month_num],
                'lag_1': [lag_1],
                'lag_12': [lag_12],
            },
            index=[dt],
        )

        y_hat = float(state.get_forecast(steps=1, exog=x_next).predicted_mean.iloc[0])
        preds.append(y_hat)

        y_new = pd.Series([y_hat], index=[dt])
        hist = pd.concat([hist, y_new])
        state = state.append(endog=y_new, exog=x_next, refit=False)

    return pd.Series(preds, index=future_index)


main_fc = recursive_forecast_with_exog(
