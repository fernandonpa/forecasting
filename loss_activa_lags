def build_exog_from_series(y: pd.Series, acc_series: pd.Series) -> pd.DataFrame:
    idx = pd.to_datetime(y.index)
    exog = pd.DataFrame(index=y.index)
    exog['active_accounts'] = acc_series.reindex(y.index).astype(float)
    exog['month_num'] = idx.month.astype(int)
    exog['lag_1'] = y.shift(1)
    exog['lag_12'] = y.shift(12)
    return exog


# Build training exog and align after lag NaNs
